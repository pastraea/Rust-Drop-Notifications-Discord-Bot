{
    "name": "rust-drops-reminder-bot",
    "version": "0.1.3",
    "private": true,
    "description": "Discord reminder bot for Twitch and Kick Rust drops",
    "author": "Thomas Benton",
    "license": "MIT",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx src/index.ts",
        "build": "tsc -p tsconfig.json",
        "test": "tsx --test src/**/*.test.ts",
        "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=html tsx --test src/**/*.test.ts",
        "start": "node dist/index.js",
        "deploy-commands": "tsx src/commands/registerCommands.ts"
    },
    "dependencies": {
        "better-sqlite3": "^12.8.0",
        "discord.js": "^14.26.2",
        "dotenv": "^17.3.1",
        "ffmpeg-static": "^5.3.0",
        "gifwrap": "^0.10.1",
        "undici": "7.24.4",
        "zod": "^4.3.6"
    },
    "overrides": {
        "undici": "$undici"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^25.5.0",
        "c8": "^11.0.0",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    }
}